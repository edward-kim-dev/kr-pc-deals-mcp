# SearchLowerPrice MCP 서버 설정

# Zyte 프록시 설정 (선택사항)
# 다나와/컴퓨존에서 요청이 차단(403/429)될 때 자동으로 Zyte 프록시를 경유합니다.
# https://www.zyte.com 에서 API 키를 발급받으세요.
# 미설정 시 직접 요청만 사용합니다.
ZYTE_API_KEY=your_zyte_api_key_here

# 캐시 TTL (초)
CACHE_TTL_SEARCH=1800
CACHE_TTL_PRODUCT=3600
CACHE_TTL_HISTORY=21600

# 요청 딜레이 (밀리초)
REQUEST_DELAY_MS=1500
